# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Payment (Stripe for international, Alipay/WeChat for China)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Credit System Pricing (CNY)
STRIPE_PRICE_ID_CREDIT_1=your-price-id-for-1-credit-¥9.9
STRIPE_PRICE_ID_CREDIT_5=your-price-id-for-5-credits-¥49
STRIPE_PRICE_ID_CREDIT_12=your-price-id-for-12-credits-¥99

# AI (DashScope for Qwen3.5-Plus)
DASHSCOPE_API_KEY=your-dashscope-api-key  # 从 https://dashscope.console.aliyun.com/ 获取
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Search (Tavily for market research)
TAVILY_API_KEY=your-tavily-api-key  # 从 https://app.tavily.com/home 获取

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000  # 生产环境使用 Render URL
